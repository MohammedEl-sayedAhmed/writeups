---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latest = posts[0];
const slugify = (t: string) => t.toLowerCase().replace(/\s+/g, '-');
const latestTags = latest?.data.tags
	? latest.data.tags.split(',').map((t) => t.trim()).filter(Boolean)
	: [];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="hero-shell">
				<div class="dot-grid" aria-hidden="true"></div>
				<div class="container container--prose">
					<section class="hero">
						<h1>{SITE_DESCRIPTION}</h1>
						<p class="lead">
							I build software and write about it. Sometimes about the elegant parts,
							sometimes about the messy ones — both tend to teach more than the polished
							tutorials do.
						</p>
					</section>
				</div>
			</div>

			<div class="container container--prose">
				{
					latest && (
						<section class="latest" aria-labelledby="latest-label">
							<div class="latest-head">
								<span id="latest-label" class="eyebrow">Latest writeup</span>
								<a href="/blog" class="all-link">All writeups →</a>
							</div>
							<a href={`/blog/${latest.id}/`} class="post-card">
								<div class="card-meta">
									<FormattedDate date={latest.data.pubDate} />
								</div>
								<h2 class="card-title" transition:name={`post-title-${latest.id}`}>{latest.data.title}</h2>
								<p class="card-desc">{latest.data.description}</p>
								{latestTags.length > 0 && (
									<ul class="tag-chips">
										{latestTags.map((t) => (
											<li>{t}</li>
										))}
									</ul>
								)}
								<span class="card-cta">Read the writeup →</span>
							</a>
						</section>
					)
				}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero-shell {
		position: relative;
		isolation: isolate;
		padding-block: var(--space-8) var(--space-12);
	}
	.dot-grid {
		position: absolute;
		inset: 0;
		z-index: -1;
		background-image: radial-gradient(
			circle at 1.5px 1.5px,
			var(--text-subtle) 1.5px,
			transparent 0
		);
		background-size: 22px 22px;
		mask-image: radial-gradient(
			ellipse 95% 75% at 50% 35%,
			black 35%,
			transparent 100%
		);
		-webkit-mask-image: radial-gradient(
			ellipse 95% 75% at 50% 35%,
			black 35%,
			transparent 100%
		);
	}

	.hero h1 {
		font-size: var(--text-6xl);
		letter-spacing: -0.035em;
		margin-bottom: var(--space-6);
	}
	.lead {
		font-size: var(--text-lg);
		color: var(--text-muted);
		margin: 0;
		max-width: 36rem;
	}
	.latest {
		margin-top: var(--space-12);
	}
	.latest-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: var(--space-5);
		padding-bottom: var(--space-3);
		border-bottom: 1px solid var(--border);
	}
	.eyebrow {
		font-size: var(--text-xs);
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-subtle);
	}
	.all-link {
		font-size: var(--text-sm);
		color: var(--text-muted);
		text-decoration: none;
	}
	.all-link:hover {
		color: var(--text);
	}
	.post-card {
		display: block;
		padding: var(--space-6);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		background: var(--bg);
		text-decoration: none;
		color: inherit;
		transition:
			border-color var(--transition),
			background var(--transition);
	}
	.post-card:hover {
		border-color: var(--border-strong);
		background: var(--bg-elevated);
	}
	.card-meta {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		font-size: var(--text-sm);
		color: var(--text-muted);
		margin-bottom: var(--space-3);
	}
	.card-title {
		font-size: var(--text-2xl);
		margin: 0 0 var(--space-3);
		color: var(--text);
		letter-spacing: -0.02em;
	}
	.card-desc {
		font-size: var(--text-base);
		color: var(--text-muted);
		margin: 0 0 var(--space-4);
	}
	.tag-chips {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		list-style: none;
		margin: 0 0 var(--space-5);
		padding: 0;
	}
	.tag-chips li {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--text-muted);
		padding: 3px 9px;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: var(--bg-subtle);
	}
	.card-cta {
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--accent);
	}

	@media (max-width: 640px) {
		.latest-head {
			flex-wrap: wrap;
			gap: var(--space-2);
		}
		.post-card {
			padding: var(--space-5);
		}
	}
</style>
