---
import { shareUrls } from '../lib/share';

interface Props {
	title: string;
	url: string;
	description: string;
	devtoUrl?: string;
}

const { title, url, description, devtoUrl } = Astro.props;
const urls = shareUrls({ title, url, description });
---

<aside
	class="post-share"
	data-share-url={url}
	data-share-title={title}
>
	{
		devtoUrl && (
			<p class="discuss-cta">
				<a href={devtoUrl} target="_blank" rel="noopener">
					Discuss on dev.to →
				</a>
			</p>
		)
	}
	<button type="button" class="share-trigger" data-open-share-sheet aria-haspopup="dialog">
		<svg
			class="trigger-icon"
			viewBox="0 0 24 24"
			width="16"
			height="16"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path>
			<polyline points="16 6 12 2 8 6"></polyline>
			<line x1="12" y1="2" x2="12" y2="15"></line>
		</svg>
		Share
	</button>

	<div class="share-overlay" data-share-overlay aria-hidden="true">
		<div
			class="share-sheet"
			role="dialog"
			aria-modal="true"
			aria-labelledby="share-sheet-heading"
		>
			<div class="sheet-handle" aria-hidden="true"></div>
			<header class="sheet-head">
				<h2 id="share-sheet-heading">Share this post</h2>
				<button type="button" class="sheet-close" data-close-share-sheet aria-label="Close">
					<svg
						viewBox="0 0 24 24"
						width="20"
						height="20"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<line x1="6" y1="6" x2="18" y2="18"></line>
						<line x1="6" y1="18" x2="18" y2="6"></line>
					</svg>
				</button>
			</header>
			<ul class="sheet-list" role="menu">
				<li role="none">
					<a role="menuitem" href={urls.x} target="_blank" rel="noopener">
						<svg class="brand-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M14.234 10.162 22.977 0h-2.072l-7.591 8.824L7.251 0H.258l9.168 13.343L.258 24H2.33l8.016-9.318L16.749 24h6.993zm-2.837 3.299-.929-1.329L3.076 1.56h3.182l5.965 8.532.929 1.329 7.754 11.09h-3.182z"/></svg>
						<span>X</span>
					</a>
				</li>
				<li role="none">
					<a role="menuitem" href={urls.linkedin} target="_blank" rel="noopener">
						<svg class="brand-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						<span>LinkedIn</span>
					</a>
				</li>
				<li role="none">
					<a role="menuitem" href={urls.bluesky} target="_blank" rel="noopener">
						<svg class="brand-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M5.202 2.857C7.954 4.922 10.913 9.11 12 11.358c1.087-2.247 4.046-6.436 6.798-8.501C20.783 1.366 24 .213 24 3.883c0 .732-.42 6.156-.667 7.037-.856 3.061-3.978 3.842-6.755 3.37 4.854.826 6.089 3.562 3.422 6.299-5.065 5.196-7.28-1.304-7.847-2.97-.104-.305-.152-.448-.153-.327 0-.121-.05.022-.153.327-.568 1.666-2.782 8.166-7.847 2.97-2.667-2.737-1.432-5.473 3.422-6.3-2.777.473-5.899-.308-6.755-3.369C.42 10.04 0 4.615 0 3.883c0-3.67 3.217-2.517 5.202-1.026"/></svg>
						<span>Bluesky</span>
					</a>
				</li>
				<li role="none">
					<a role="menuitem" href={urls.hackernews} target="_blank" rel="noopener">
						<svg class="brand-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M0 24V0h24v24H0zM6.951 5.896l4.112 7.708v5.064h1.583v-4.972l4.148-7.799h-1.749l-2.457 4.875c-.372.745-.688 1.434-.688 1.434s-.297-.708-.651-1.434L8.831 5.896h-1.88z"/></svg>
						<span>Hacker News</span>
					</a>
				</li>
				<li role="none">
					<a role="menuitem" href={urls.reddit} target="_blank" rel="noopener">
						<svg class="brand-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12c0 3.314 1.343 6.314 3.515 8.485l-2.286 2.286C.775 23.225 1.097 24 1.738 24H12c6.627 0 12-5.373 12-12S18.627 0 12 0Zm4.388 3.199c1.104 0 1.999.895 1.999 1.999 0 1.105-.895 2-1.999 2-.946 0-1.739-.657-1.947-1.539v.002c-1.147.162-2.032 1.15-2.032 2.341v.007c1.776.067 3.4.567 4.686 1.363.473-.363 1.064-.58 1.707-.58 1.547 0 2.802 1.254 2.802 2.802 0 1.117-.655 2.081-1.601 2.531-.088 3.256-3.637 5.876-7.997 5.876-4.361 0-7.905-2.617-7.998-5.87-.954-.447-1.614-1.415-1.614-2.538 0-1.548 1.255-2.802 2.803-2.802.645 0 1.239.218 1.712.585 1.275-.79 2.881-1.291 4.64-1.365v-.01c0-1.663 1.263-3.034 2.88-3.207.188-.911.993-1.595 1.959-1.595Zm-8.085 8.376c-.784 0-1.459.78-1.506 1.797-.047 1.016.64 1.429 1.426 1.429.786 0 1.371-.369 1.418-1.385.047-1.017-.553-1.841-1.338-1.841Zm7.406 0c-.786 0-1.385.824-1.338 1.841.047 1.017.634 1.385 1.418 1.385.785 0 1.473-.413 1.426-1.429-.046-1.017-.721-1.797-1.506-1.797Zm-3.703 4.013c-.974 0-1.907.048-2.77.135-.147.015-.241.168-.183.305.483 1.154 1.622 1.964 2.953 1.964 1.33 0 2.47-.81 2.953-1.964.057-.137-.037-.29-.184-.305-.863-.087-1.795-.135-2.769-.135Z"/></svg>
						<span>Reddit</span>
					</a>
				</li>
				<li role="none">
					<button role="menuitem" type="button" data-share="mastodon">
						<svg class="brand-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054c1.517.363 3.072.546 4.632.546.376 0 .75 0 1.125-.01 1.57-.044 3.224-.124 4.768-.422.038-.008.077-.015.11-.024 2.435-.464 4.753-1.92 4.989-5.604.008-.145.03-1.52.03-1.67.002-.512.167-3.63-.024-5.545zm-3.748 9.195h-2.561V8.29c0-1.309-.55-1.976-1.67-1.976-1.23 0-1.846.79-1.846 2.35v3.403h-2.546V8.663c0-1.56-.617-2.35-1.848-2.35-1.112 0-1.668.668-1.67 1.977v6.218H4.822V8.102c0-1.31.337-2.35 1.011-3.12.696-.77 1.608-1.164 2.74-1.164 1.311 0 2.302.5 2.962 1.498l.638 1.06.638-1.06c.66-.999 1.65-1.498 2.96-1.498 1.13 0 2.043.395 2.74 1.164.675.77 1.012 1.81 1.012 3.12z"/></svg>
						<span>Mastodon</span>
					</button>
				</li>
				<li role="none">
					<a role="menuitem" href={urls.email}>
						<svg class="brand-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6zm-2 0l-8 5-8-5h16zm0 12H4V8l8 5 8-5v10z"/></svg>
						<span>Email</span>
					</a>
				</li>
				<li role="none">
					<button role="menuitem" type="button" data-share="copy">
						<svg class="brand-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/></svg>
						<span class="copy-label">Copy link</span>
					</button>
				</li>
			</ul>
		</div>
	</div>
</aside>

<script>
	function openSheet(overlay: HTMLElement) {
		overlay.setAttribute('data-open', 'true');
		overlay.setAttribute('aria-hidden', 'false');
		document.body.style.overflow = 'hidden';
		// Focus first interactive element inside for keyboard users.
		const first = overlay.querySelector<HTMLElement>('a, button');
		first?.focus({ preventScroll: true });
	}

	function closeSheet(overlay: HTMLElement) {
		overlay.removeAttribute('data-open');
		overlay.setAttribute('aria-hidden', 'true');
		document.body.style.overflow = '';
	}

	// Document-level delegation; survives Astro soft navigations.
	document.addEventListener('click', async (event) => {
		const target = event.target;
		if (!(target instanceof Element)) return;

		// Open trigger
		const opener = target.closest<HTMLButtonElement>('[data-open-share-sheet]');
		if (opener) {
			const root = opener.closest('.post-share');
			const overlay = root?.querySelector<HTMLElement>('[data-share-overlay]');
			if (overlay) openSheet(overlay);
			return;
		}

		// Close (X button or backdrop click outside the sheet)
		const closeBtn = target.closest<HTMLButtonElement>('[data-close-share-sheet]');
		if (closeBtn) {
			const overlay = closeBtn.closest<HTMLElement>('[data-share-overlay]');
			if (overlay) closeSheet(overlay);
			return;
		}
		if (target.matches('[data-share-overlay]')) {
			closeSheet(target as HTMLElement);
			return;
		}

		// Clicking a menuitem (link or action button) inside the sheet
		const item = target.closest('.sheet-list a, .sheet-list button');
		if (item) {
			const overlay = item.closest<HTMLElement>('[data-share-overlay]');
			const btn = target.closest<HTMLButtonElement>('[data-share]');
			if (btn && overlay) {
				const root = overlay.closest('.post-share');
				const url = root?.getAttribute('data-share-url') ?? '';
				const title = root?.getAttribute('data-share-title') ?? '';
				const action = btn.getAttribute('data-share');

				if (action === 'mastodon') {
					let saved = '';
					try {
						saved = localStorage.getItem('mastodonInstance') ?? '';
					} catch (e) {}
					const entered = window.prompt(
						'Your Mastodon instance (e.g. mastodon.social):',
						saved,
					);
					if (!entered) return;
					const clean = entered.trim().replace(/^https?:\/\//, '').replace(/\/+$/, '');
					if (!clean) return;
					try {
						localStorage.setItem('mastodonInstance', clean);
					} catch (e) {}
					window.open(
						`https://${clean}/share?text=${encodeURIComponent(`${title} ${url}`)}`,
						'_blank',
						'noopener',
					);
					closeSheet(overlay);
					return;
				}

				if (action === 'copy') {
					const label = btn.querySelector('.copy-label');
					const original = label?.textContent ?? 'Copy link';
					try {
						await navigator.clipboard.writeText(url);
						if (label) label.textContent = 'Copied';
						btn.setAttribute('data-copied', 'true');
					} catch (e) {
						if (label) label.textContent = 'Failed';
					}
					setTimeout(() => {
						if (label) label.textContent = original;
						btn.removeAttribute('data-copied');
					}, 1500);
					return;
				}
			}
			// External link: close the sheet (link's own target=_blank still navigates).
			if (overlay) closeSheet(overlay);
		}
	});

	// Escape closes any open share sheet.
	document.addEventListener('keydown', (event) => {
		if (event.key !== 'Escape') return;
		document.querySelectorAll<HTMLElement>('[data-share-overlay][data-open]').forEach((o) =>
			closeSheet(o),
		);
	});
</script>

<style>
	/* Sits inside `.article-head`; align with the row of tag chips above. */
	.post-share {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-4);
		margin-top: var(--space-5);
	}
	.discuss-cta {
		margin: 0;
		font-size: var(--text-sm);
	}
	.discuss-cta a {
		font-weight: 600;
		color: var(--text);
		text-decoration: underline;
		text-decoration-color: var(--accent);
		text-decoration-thickness: 2px;
		text-underline-offset: 0.22em;
	}
	.discuss-cta a:hover {
		text-decoration-color: var(--text);
	}

	.share-trigger {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--text-muted);
		padding: 6px 12px;
		border: 1px solid var(--border);
		border-radius: var(--radius-sm);
		background: var(--bg);
		cursor: pointer;
		transition:
			color var(--transition-fast),
			border-color var(--transition-fast),
			background var(--transition-fast);
	}
	.share-trigger:hover {
		color: var(--text);
		border-color: var(--border-strong);
		background: var(--bg-elevated);
	}
	.trigger-icon {
		flex-shrink: 0;
	}

	/* Overlay + sheet */
	.share-overlay {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: none;
		background: rgba(0, 0, 0, 0.5);
		align-items: flex-end;
		justify-content: center;
	}
	.share-overlay[data-open] {
		display: flex;
		animation: share-fade 180ms ease;
	}
	.share-sheet {
		/* Flex column with capped height so on short viewports (iOS Safari with
		 visible URL bar) the X stays in view and the menu rows scroll inside.
		 Horizontal containment: box-sizing keeps padding inside the 100% width,
		 overflow-x clips any rogue child, and min-width:0 lets flex children
		 shrink rather than push the close button off the right edge. */
		display: flex;
		flex-direction: column;
		box-sizing: border-box;
		width: 100%;
		max-width: min(520px, 100%);
		max-height: 90dvh;
		min-width: 0;
		overflow-x: hidden;
		background: var(--bg);
		border-radius: var(--radius-lg) var(--radius-lg) 0 0;
		padding: var(--space-3) var(--space-4) calc(var(--space-4) + env(safe-area-inset-bottom, 0));
		animation: share-slide 220ms cubic-bezier(0.2, 0.7, 0.2, 1);
	}
	@media (min-width: 480px) {
		.share-sheet {
			padding-inline: var(--space-5);
		}
	}
	@media (min-width: 640px) {
		.share-overlay {
			align-items: center;
		}
		.share-sheet {
			border-radius: var(--radius-lg);
			margin-block: var(--space-6);
			max-height: calc(100dvh - 2 * var(--space-6));
			animation: share-pop 220ms cubic-bezier(0.2, 0.7, 0.2, 1);
		}
	}
	.sheet-handle {
		width: 36px;
		height: 4px;
		background: var(--border-strong);
		border-radius: 4px;
		margin: 0 auto var(--space-3);
	}
	@media (min-width: 640px) {
		.sheet-handle {
			display: none;
		}
	}
	.sheet-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-3);
		min-width: 0;
		margin-bottom: var(--space-2);
	}
	.sheet-head h2 {
		flex: 1 1 0;
		min-width: 0;
		font-size: var(--text-lg);
		font-weight: 700;
		margin: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.sheet-close {
		flex-shrink: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		background: transparent;
		border: 0;
		color: var(--text-muted);
		border-radius: var(--radius-sm);
		cursor: pointer;
	}
	.sheet-close:hover {
		color: var(--text);
		background: var(--bg-subtle);
	}

	.sheet-list {
		list-style: none;
		margin: 0;
		padding: 0;
		/* Sticky header stays visible while these rows scroll on short screens. */
		overflow-y: auto;
		flex: 1 1 auto;
		min-height: 0;
		overscroll-behavior: contain;
	}
	.sheet-list a,
	.sheet-list button {
		display: flex;
		align-items: center;
		gap: var(--space-4);
		width: 100%;
		text-align: left;
		padding: 14px 6px;
		font-family: var(--font-sans);
		font-size: var(--text-base);
		font-weight: 500;
		color: var(--text);
		background: transparent;
		border: 0;
		text-decoration: none;
		cursor: pointer;
		border-radius: var(--radius-sm);
		transition: background var(--transition-fast);
	}
	.sheet-list li + li a,
	.sheet-list li + li button {
		border-top: 1px solid var(--border);
		border-radius: 0;
	}
	.sheet-list a:hover,
	.sheet-list button:hover,
	.sheet-list a:focus-visible,
	.sheet-list button:focus-visible {
		background: var(--bg-subtle);
		outline: none;
	}
	.brand-icon {
		flex-shrink: 0;
		color: var(--text);
	}
	.sheet-list button[data-copied='true'] .copy-label {
		color: var(--accent);
	}

	@keyframes share-fade {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}
	@keyframes share-slide {
		from {
			transform: translateY(100%);
		}
		to {
			transform: translateY(0);
		}
	}
	@keyframes share-pop {
		from {
			opacity: 0;
			transform: scale(0.96);
		}
		to {
			opacity: 1;
			transform: scale(1);
		}
	}
</style>
