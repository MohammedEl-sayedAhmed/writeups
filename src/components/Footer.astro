---
import { AUTHOR_NAME, SOCIALS } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer" data-pagefind-ignore>
	<div class="container footer-row">
		<p class="copyright">© {year} {AUTHOR_NAME}</p>
		<ul class="socials">
			<li><a href={SOCIALS.github} target="_blank" rel="me noopener">GitHub</a></li>
			<li><a href={SOCIALS.devto} target="_blank" rel="noopener">dev.to</a></li>
			<li><a href={SOCIALS.rss}>RSS</a></li>
		</ul>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--border);
		padding-block: var(--space-8);
		margin-top: var(--space-16);
	}
	.footer-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-4);
		flex-wrap: wrap;
	}
	.copyright {
		margin: 0;
		font-size: var(--text-sm);
		color: var(--text-muted);
	}
	.socials {
		display: flex;
		gap: var(--space-5);
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.socials a {
		font-size: var(--text-sm);
		color: var(--text);
		text-decoration: none;
		transition: color var(--transition-fast);
	}
	.socials a:hover {
		color: var(--accent);
	}
</style>
